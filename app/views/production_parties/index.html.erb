<div class="wrap">
  <%= render "shared/sidebar" %>
  <div class="main">
    <div class="top">
      <div><h1>🧷 Production Parties</h1><p class="page-sub">Stitching persons/groups — used as columns on the Production Sheet and for sending suits to stitching.</p></div>
      <% unless current_user.view_only? %><%= link_to "＋ Add person", new_production_party_path, class: "btn-primary" %><% end %>
    </div>
    <div class="party-grid">
      <% @parties.each do |p| %>
        <div class="party-card pp-card">
          <%= link_to production_party_path(p), class: "pp-card-link" do %>
            <div class="pp-card-top">
              <div class="party-avatar"><% if p.photo.attached? %><%= image_tag rails_blob_path(p.photo), alt: p.name %><% else %><%= p.name.to_s.first.to_s.upcase %><% end %></div>
              <div class="party-body">
                <div class="party-name"><%= p.name %></div>
                <% if p.contact.present? %><div class="party-meta">☎ <%= p.contact %></div><% end %>
                <% if p.family_contact.present? %><div class="party-meta muted">👨‍👩‍👧 <%= p.family_contact %></div><% end %>
                <% if p.balance != 0 %><div class="party-meta pp-owe">💵 We owe <b><%= rs(p.balance) %></b></div><% end %>
              </div>
            </div>
            <div class="pp-cnic-thumbs">
              <div class="pp-thumb"><span>Front</span>
                <% if p.cnic_front.attached? %><%= image_tag rails_blob_path(p.cnic_front) %><% else %><em>—</em><% end %></div>
              <div class="pp-thumb"><span>Back</span>
                <% if p.cnic_back.attached? %><%= image_tag rails_blob_path(p.cnic_back) %><% else %><em>—</em><% end %></div>
            </div>
          <% end %>
          <% unless current_user.view_only? %>
            <div class="party-actions">
              <%= link_to "Open", production_party_path(p), class: "btn-sm edit" %>
              <%= link_to "Edit", edit_production_party_path(p), class: "btn-sm edit" %>
              <%= button_to "Delete", production_party_path(p), method: :delete, class: "btn-sm del", form: { style: "display:inline" }, data: { turbo_confirm: "Delete #{p.name}?" } %>
            </div>
          <% end %>
        </div>
      <% end %>
      <% if @parties.empty? %><p class="muted" style="padding:24px">No production parties yet.</p><% end %>
    </div>
  </div>
</div>
