<div class="emb-row">
  <%= ef.text_field :file_name, placeholder: "Panel", class: "ef-name" %>
  <%= ef.number_field :stitch, placeholder: "Stitch" %>
  <%= ef.number_field :heads, step: 0.5, placeholder: "Head" %>
  <%= ef.number_field :rate, step: 0.01, placeholder: "Rate" %>
  <span class="ef-total" data-total>—</span>
  <%= ef.hidden_field :reapts, value: 1 %>   <%# always 1 %>
  <%= ef.hidden_field :_destroy, value: 0, class: "ef-destroy" %>
  <button type="button" class="ef-remove" title="Remove">✕</button>
</div>
