<div class="addon2-row">
  <%= af.hidden_field :target %>
  <%= af.text_field :label, placeholder: "Label (e.g. Handling)" %>
  <%= af.number_field :amount, step: 0.01, placeholder: "Amount" %>
  <%= af.hidden_field :_destroy, value: 0, class: "a2-destroy" %>
  <button type="button" class="a2-remove" title="Remove">✕</button>
</div>
